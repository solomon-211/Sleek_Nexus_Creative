# Environment Configuration Template
# Copy this to .env and fill in your values

# ========================================
# Node Environment
# ========================================
NODE_ENV=development

# ========================================
# MongoDB Configuration
# ========================================
MONGODB_USER=admin
MONGODB_PASSWORD=change_me_in_production
MONGODB_PORT=27017
MONGODB_URI=mongodb://admin:change_me_in_production@mongodb:27017/codebridge?authSource=admin

# ========================================
# Backend Server
# ========================================
PORT=5000
HOST=localhost
JWT_SECRET=your_secret_key_must_be_at_least_32_characters_long_change_this

# ========================================
# CORS Origins (comma-separated)
# ========================================
CORS_ORIGIN=http://localhost:3000,http://localhost:5173,http://localhost:5500,http://127.0.0.1:5173

# ========================================
# Rate Limiting
# ========================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ========================================
# Email Configuration (Nodemailer)
# ========================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_specific_password
EMAIL_FROM=noreply@sleeknexuscreative.ss

# ========================================
# Payment Processing (Stripe)
# ========================================
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key

# ========================================
# reCAPTCHA
# ========================================
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key
RECAPTCHA_SITE_KEY=your_recaptcha_site_key

# ========================================
# SendGrid (Optional alternative to Nodemailer)
# ========================================
SENDGRID_API_KEY=SG.your_sendgrid_api_key

# ========================================
# Logging & Analytics
# ========================================
LOG_LEVEL=debug
SENTRY_DSN=https://your_sentry_dsn

# ========================================
# File Upload
# ========================================
MAX_UPLOAD_SIZE=10mb
UPLOAD_DIR=./uploads

# ========================================
# Database Backup
# ========================================
BACKUP_ENABLED=false
BACKUP_SCHEDULE=0 2 * * *

# ========================================
# Feature Flags
# ========================================
ENABLE_GRAPHQL=true
ENABLE_WEBSOCKET=true
ENABLE_PAYMENTS=true
ENABLE_EMAIL_VERIFICATION=true
