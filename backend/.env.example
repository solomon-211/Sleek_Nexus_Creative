# ═══════════════════════════════════════════════════════════════════════════════
# Sleek Nexus Creative — Backend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development          # development | production | test
PORT=5000
HOST=0.0.0.0

# ── Database ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/snc
MONGODB_POOL_SIZE=10
MONGODB_TIMEOUT=5000

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_64_char_random_hex_string
JWT_EXPIRES_IN=7d

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# ── Frontend URL (used in email links) ───────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Email ─────────────────────────────────────────────────────────────────────
# Option A: SMTP (Gmail, Outlook, etc.)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-specific-password
EMAIL_FROM=noreply@snc.ss

# Option B: SendGrid (takes priority if set)
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx

# Admin notification email (receives contact form submissions)
ADMIN_EMAIL=admin@snc.ss

# ── Admin setup ───────────────────────────────────────────────────────────────
# Used once to create the first admin account via POST /api/admin/setup
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SETUP_KEY=replace_with_a_random_secret_key

# ── reCAPTCHA v3 ──────────────────────────────────────────────────────────────
# Get from: https://www.google.com/recaptcha/admin
RECAPTCHA_SECRET_KEY=your_recaptcha_v3_secret_key
RECAPTCHA_MIN_SCORE=0.5

# ── Stripe Payments ───────────────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# ── File Uploads ──────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880          # 5 MB in bytes

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000    # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100

# ── Request body limits ───────────────────────────────────────────────────────
JSON_LIMIT=10mb
URL_ENCODED_LIMIT=10mb

# ── MongoDB Docker (used by docker-compose only) ──────────────────────────────
MONGODB_USER=admin
MONGODB_PASSWORD=change_me_in_production
MONGODB_PORT=27017
